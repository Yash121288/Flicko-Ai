<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:centerColor="#EFF8F2"
                android:endColor="#DFF3E5"
                android:startColor="#FAFCF8"
                android:type="linear" />
        </shape>
    </item>

    <item
        android:gravity="bottom"
        android:height="210dp">
        <shape android:shape="rectangle">
            <solid android:color="#E7F4EE" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:height="112dp"
        android:width="224dp">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/flicko_splash_wordmark" />
    </item>
</layer-list>
