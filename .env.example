DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://flickoai-d4i2i.ondigitalocean.app
CSRF_TRUSTED_ORIGINS=https://api.example.com
# Optional App Platform bindable vars. If set, settings.py auto-adds them to
# ALLOWED_HOSTS / CSRF trusted origins.
APP_DOMAIN=api.example.com
APP_URL=https://api.example.com
DJANGO_SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=false
DJANGO_LOG_LEVEL=INFO

# Supabase PostgreSQL (primary production database)
# Use the pooled or direct Postgres URL from Supabase.
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_SSL_REQUIRE=true
DATABASE_CONN_MAX_AGE=600

# Cloudinary raw-file storage for generated PDFs / HTML reports / uploads.
# Keep USE_CLOUDINARY_MEDIA=false for local development if you want local MEDIA_ROOT.
USE_CLOUDINARY_MEDIA=true
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_MEDIA_PREFIX=flicko
# upload, private, or authenticated. Use authenticated for health-report privacy.
CLOUDINARY_DELIVERY_TYPE=authenticated
CLOUDINARY_INVALIDATE=true

# SMTP. Copy this file to .env and fill these values.
# For Gmail, use an App Password, not your normal Gmail password.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Flicko AI <no-reply@flicko.local>

# OTP security
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Google login. This OAuth client ID is public; do not put an OAuth client secret in the mobile app.
GOOGLE_OAUTH_CLIENT_IDS=782174705998-7l0035suockngjdvbhbue651sv6cemll.apps.googleusercontent.com
GOOGLE_OAUTH_ALLOW_UNCONFIGURED_DEBUG=true

# Optional backend AI analyzer for full call/chat transcript -> dashboard data,
# reminders, tasks, and PDF report markdown. Leave blank to use local fallback.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=22
