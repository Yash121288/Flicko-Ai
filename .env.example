DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP. Copy this file to .env and fill these values.
# For Gmail, use an App Password, not your normal Gmail password.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Flicko AI <no-reply@flicko.local>

# OTP security
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Google login. Use the Web OAuth client ID that also goes into Flutter as
# --dart-define=FLICKO_GOOGLE_SERVER_CLIENT_ID=...
GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_ALLOW_UNCONFIGURED_DEBUG=true

# Flutter Google Sign-In runtime values used by run_dev.ps1.
# Android often reads app config from google-services.json in production, but
# passing these during dev keeps the local run path explicit.
FLICKO_GOOGLE_CLIENT_ID=your-android-or-web-client-id.apps.googleusercontent.com
FLICKO_GOOGLE_SERVER_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Optional backend AI analyzer for full call/chat transcript -> dashboard data,
# reminders, tasks, and PDF report markdown. Leave blank to use local fallback.
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=22
